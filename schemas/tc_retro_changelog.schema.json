{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tc_retro_changelog.schema.json",
  "title": "TC Retro Changelog",
  "description": "Input format for /tc retro — batch retroactive TC creation from a structured changelog",
  "type": "object",
  "required": ["project", "changes"],
  "properties": {
    "project": {
      "type": "string",
      "minLength": 1,
      "description": "Project name (must match tc_config.json project_name)"
    },
    "default_author": {
      "type": "string",
      "default": "retroactive",
      "description": "Default author for all retroactive entries"
    },
    "changes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["title", "scope", "description"],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 5,
            "maxLength": 120,
            "description": "TC title"
          },
          "scope": {
            "type": "string",
            "enum": ["feature", "bugfix", "refactor", "infrastructure", "documentation", "hotfix", "enhancement"],
            "description": "Change type"
          },
          "priority": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"],
            "default": "medium",
            "description": "Priority level"
          },
          "status": {
            "type": "string",
            "enum": ["planned", "in_progress", "blocked", "implemented", "tested", "deployed"],
            "default": "deployed",
            "description": "Current status (typically 'deployed' for retroactive entries)"
          },
          "date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
            "description": "Date of the change in YYYY-MM-DD format"
          },
          "description": {
            "type": "string",
            "minLength": 10,
            "description": "Summary description of what changed and why"
          },
          "motivation": {
            "type": ["string", "null"],
            "default": null,
            "description": "Why this change was needed (optional, defaults to description)"
          },
          "detailed_design": {
            "type": ["string", "null"],
            "default": null,
            "description": "Technical design notes"
          },
          "files": {
            "type": "array",
            "items": { "type": "string" },
            "default": [],
            "description": "Files affected (relative paths)"
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" },
            "default": [],
            "description": "Freeform tags"
          },
          "version": {
            "type": ["string", "null"],
            "default": null,
            "description": "Version string if applicable (e.g., 'v7.1.0')"
          },
          "breaking_changes": {
            "type": "array",
            "items": { "type": "string" },
            "default": [],
            "description": "List of breaking changes"
          },
          "dependencies": {
            "type": "array",
            "items": { "type": "string" },
            "default": [],
            "description": "External dependencies"
          },
          "related_indices": {
            "type": "array",
            "items": { "type": "integer", "minimum": 0 },
            "default": [],
            "description": "Indices of related changes in this changelog (0-based)"
          }
        },
        "additionalProperties": false
      },
      "description": "Array of changes to create TC records for"
    }
  },
  "additionalProperties": false
}