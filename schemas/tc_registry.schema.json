{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tc_registry.schema.json",
  "title": "TC Registry",
  "description": "Master index of all TC records in a project. System of record for TC enumeration and status overview.",
  "type": "object",
  "required": [
    "project_name",
    "created",
    "updated",
    "next_tc_number",
    "records",
    "statistics"
  ],
  "properties": {
    "project_name": {
      "type": "string",
      "minLength": 1,
      "description": "Name of the project this registry belongs to"
    },
    "created": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when this registry was created"
    },
    "updated": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last registry update"
    },
    "next_tc_number": {
      "type": "integer",
      "minimum": 1,
      "description": "Next sequential TC number to assign"
    },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tc_id", "title", "status", "scope", "priority", "created", "updated", "path"],
        "properties": {
          "tc_id": {
            "type": "string",
            "description": "TC identifier matching the record's tc_id"
          },
          "title": {
            "type": "string",
            "description": "TC title for display in dashboard"
          },
          "status": {
            "type": "string",
            "enum": ["planned", "in_progress", "blocked", "implemented", "tested", "deployed"],
            "description": "Current TC status (must match the record)"
          },
          "scope": {
            "type": "string",
            "enum": ["feature", "bugfix", "refactor", "infrastructure", "documentation", "hotfix", "enhancement"],
            "description": "TC scope/type"
          },
          "priority": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"],
            "description": "TC priority"
          },
          "created": {
            "type": "string",
            "format": "date-time",
            "description": "TC creation timestamp"
          },
          "updated": {
            "type": "string",
            "format": "date-time",
            "description": "TC last update timestamp"
          },
          "path": {
            "type": "string",
            "description": "Relative path to TC record directory from docs/TC/"
          },
          "sub_tc_count": {
            "type": "integer",
            "minimum": 0,
            "default": 0,
            "description": "Number of sub-TCs"
          },
          "test_summary": {
            "type": "object",
            "properties": {
              "total": { "type": "integer", "minimum": 0 },
              "pass": { "type": "integer", "minimum": 0 },
              "fail": { "type": "integer", "minimum": 0 },
              "pending": { "type": "integer", "minimum": 0 },
              "skip": { "type": "integer", "minimum": 0 },
              "blocked": { "type": "integer", "minimum": 0 }
            },
            "additionalProperties": false,
            "default": { "total": 0, "pass": 0, "fail": 0, "pending": 0, "skip": 0, "blocked": 0 },
            "description": "Aggregated test case status"
          }
        },
        "additionalProperties": false
      },
      "default": [],
      "description": "Summary entries for all TC records in this project"
    },
    "statistics": {
      "type": "object",
      "required": ["total", "by_status", "by_scope", "by_priority"],
      "properties": {
        "total": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of TC records"
        },
        "by_status": {
          "type": "object",
          "properties": {
            "planned": { "type": "integer", "minimum": 0, "default": 0 },
            "in_progress": { "type": "integer", "minimum": 0, "default": 0 },
            "blocked": { "type": "integer", "minimum": 0, "default": 0 },
            "implemented": { "type": "integer", "minimum": 0, "default": 0 },
            "tested": { "type": "integer", "minimum": 0, "default": 0 },
            "deployed": { "type": "integer", "minimum": 0, "default": 0 }
          },
          "additionalProperties": false,
          "description": "Count per implementation state"
        },
        "by_scope": {
          "type": "object",
          "properties": {
            "feature": { "type": "integer", "minimum": 0, "default": 0 },
            "bugfix": { "type": "integer", "minimum": 0, "default": 0 },
            "refactor": { "type": "integer", "minimum": 0, "default": 0 },
            "infrastructure": { "type": "integer", "minimum": 0, "default": 0 },
            "documentation": { "type": "integer", "minimum": 0, "default": 0 },
            "hotfix": { "type": "integer", "minimum": 0, "default": 0 },
            "enhancement": { "type": "integer", "minimum": 0, "default": 0 }
          },
          "additionalProperties": false,
          "description": "Count per scope category"
        },
        "by_priority": {
          "type": "object",
          "properties": {
            "critical": { "type": "integer", "minimum": 0, "default": 0 },
            "high": { "type": "integer", "minimum": 0, "default": 0 },
            "medium": { "type": "integer", "minimum": 0, "default": 0 },
            "low": { "type": "integer", "minimum": 0, "default": 0 }
          },
          "additionalProperties": false,
          "description": "Count per priority level"
        }
      },
      "additionalProperties": false,
      "description": "Aggregated statistics recomputed on every registry write"
    }
  },
  "additionalProperties": false
}